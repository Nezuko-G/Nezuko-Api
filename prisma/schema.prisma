generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("super_admins")
}

model Tenant {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  companyEmail  String   @unique @map("company_email")
  emailDomain   String   @unique @map("email_domain")
  logoUrl       String?  @map("logo_url")
  industry      String?
  country       String?
  city          String?
  address       String?
  phone         String?
  website       String?
  taxNumber     String?  @map("tax_number")
  commercialReg String?  @map("commercial_reg")
  currency      String?
  timezone      String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  users              User[]
  departments        Department[]
  insurancePlans     InsurancePlan[]
  insuranceEnrollments InsuranceEnrollment[]
  companySettings    CompanySettings?
  attendanceSettings AttendanceSettings?
  employeeDocuments  EmployeeDocument[]
  leaveRequests      LeaveRequest[]

  @@map("tenants")
}

model CompanySettings {
  id              String @id @default(uuid())
  tenantId        String @unique @map("tenant_id")
  language        String @default("ar")
  dateFormat      String @default("DD/MM/YYYY") @map("date_format")
  fiscalYearStart Int    @default(1) @map("fiscal_year_start")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

model AttendanceSettings {
  id                String  @id @default(uuid())
  tenantId          String  @unique @map("tenant_id")
  workDayStart      String  @default("09:00") @map("work_day_start")
  workDayEnd        String  @default("17:00") @map("work_day_end")
  workingDays       Int[]   @default([0, 1, 2, 3, 4]) @map("working_days")
  lateGraceMinutes  Int     @default(0) @map("late_grace_minutes")
  earlyLeaveGrace   Int     @default(0) @map("early_leave_grace")
  overtimeThreshold Int     @default(0) @map("overtime_threshold")
  roundingEnabled   Boolean @default(false) @map("rounding_enabled")
  roundingMinutes   Int?    @map("rounding_minutes")
  requireBiometric  Boolean @default(false) @map("require_biometric")
  geofenceEnabled   Boolean @default(false) @map("geofence_enabled")
  geofenceLat       Float?  @map("geofence_lat")
  geofenceLng       Float?  @map("geofence_lng")
  geofenceRadiusM   Int?    @map("geofence_radius_m")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("attendance_settings")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model User {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  email        String
  passwordHash String         @map("password_hash")
  role         UserRole       @default(EMPLOYEE)
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  // Personal Info
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  phone       String?
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  gender      Gender?

  hireDate     DateTime?      @map("hire_date") @db.Date
  jobTitle     String?        @map("job_title")
  employeeCode String?        @map("employee_code")
  status       EmployeeStatus @default(ACTIVE)
  departmentId String?        @map("department_id")
  salary       Float?         @map("salary")

  country String?
  city    String?
  address String?

  emergencyName     String? @map("emergency_name")
  emergencyPhone    String? @map("emergency_phone")
  emergencyRelation String? @map("emergency_relation")

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  department        Department?        @relation("DepartmentMembers", fields: [departmentId], references: [id])
  managedDepartments Department[]     @relation("DepartmentManager")
  employeeDocuments EmployeeDocument[]
  leaveRequests     LeaveRequest[]     @relation("EmployeeLeaves")
  reviewedLeaves    LeaveRequest[]     @relation("ReviewedLeaves")
  insuranceEnrollments InsuranceEnrollment[]

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  TENANT_OWNER
  HR_ADMIN
  MANAGER
  EMPLOYEE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum InsurancePlanType {
  BASIC
  STANDARD
  PREMIUM
}

enum DependentRelation {
  SPOUSE
  CHILD
  PARENT
}

model Department {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  managerId   String?  @map("manager_id")
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  users    User[]      @relation("DepartmentMembers")
  manager  User?       @relation("DepartmentManager", fields: [managerId], references: [id])
  parent   Department? @relation("SubDepartments", fields: [parentId], references: [id])
  children Department[] @relation("SubDepartments")

  @@unique([tenantId, name])
  @@map("departments")
}

model EmployeeDocument {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tenantId   String    @map("tenant_id")
  fileUrl    String    @map("file_url")
  fileName   String    @map("file_name")
  expiryDate DateTime? @map("expiry_date") @db.Date
  uploadedAt DateTime  @default(now()) @map("uploaded_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("employee_documents")
}

model DemoRequest {
  id            String        @id @default(uuid())
  fullName      String        @map("full_name")
  email         String
  companyName   String        @map("company_name")
  jobTitle      String        @map("job_title")
  phone         String
  employeeCount EmployeeCount @map("employee_count")
  interests     Interest[]
  converted     Boolean       @default(false)
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("demo_requests")
}

model LeaveRequest {
  id         String      @id @default(uuid())
  tenantId   String      @map("tenant_id")
  userId     String      @map("user_id")
  startDate  DateTime    @map("start_date") @db.Date
  endDate    DateTime    @map("end_date") @db.Date
  reason     String?
  status     LeaveStatus @default(PENDING)
  reviewerId String?     @map("reviewer_id")
  reviewNote String?     @map("review_note")
  reviewedAt DateTime?   @map("reviewed_at")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation("EmployeeLeaves", fields: [userId], references: [id])
  reviewer User?  @relation("ReviewedLeaves", fields: [reviewerId], references: [id])

  @@unique([tenantId, userId, startDate, endDate])
  @@map("leave_requests")
}

model InsurancePlan {
  id              String              @id @default(uuid())
  tenantId        String              @map("tenant_id")
  name            String
  type            InsurancePlanType
  coverageDetails String?             @map("coverage_details")
  salaryPercentage Float               @map("salary_percentage")
  maxDependents   Int                  @default(4) @map("max_dependents")
  isActive        Boolean              @default(true) @map("is_active")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  enrollments InsuranceEnrollment[]

  @@unique([tenantId, name])
  @@map("insurance_plans")
}

model InsuranceEnrollment {
  id                String                 @id @default(uuid())
  tenantId          String                 @map("tenant_id")
  userId            String                 @map("user_id")
  planId            String                 @map("plan_id")
  startDate         DateTime               @map("start_date") @db.Date
  endDate           DateTime?              @map("end_date") @db.Date
  monthlyCost       Float                  @map("monthly_cost")
  salaryAtEnrollment Float                 @map("salary_at_enrollment")
  isActive          Boolean                @default(true) @map("is_active")
  createdAt         DateTime               @default(now()) @map("created_at")

  tenant     Tenant                @relation(fields: [tenantId], references: [id])
  user       User                  @relation(fields: [userId], references: [id])
  plan       InsurancePlan         @relation(fields: [planId], references: [id])
  dependents InsuranceDependent[]

  @@unique([tenantId, userId, planId])
  @@map("insurance_enrollments")
}

model InsuranceDependent {
  id           String                @id @default(uuid())
  enrollmentId String                @map("enrollment_id")
  name         String
  relation     DependentRelation
  dateOfBirth  DateTime              @map("date_of_birth") @db.Date
  nationalId   String?               @map("national_id")
  createdAt    DateTime              @default(now()) @map("created_at")

  enrollment InsuranceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, nationalId])
  @@map("insurance_dependents")
}

enum EmployeeCount {
  FROM_1_TO_25
  FROM_26_TO_100
  FROM_101_TO_250
  MORE_THAN_250
}

enum Interest {
  ALL
  CORE_HR
  TALENT
  SPEND
}
